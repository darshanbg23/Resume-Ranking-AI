# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Option 1: PostgreSQL via DATABASE_URL (recommended for production)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option 2: SQLite (development default — leave DATABASE_URL empty)
# No config needed, SQLite is used automatically

# Option 3: MySQL (set USE_MYSQL=True and fill in credentials)
USE_MYSQL=False
DATABASE_NAME=resume_db
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=3306

# Groq AI API Configuration
# Get your API key from: https://console.groq.com/keys
API_KEY=your_groq_api_key_here

# Frontend URL (for CORS — required in production)
FRONTEND_URL=http://localhost:5173

# CORS Allowed Origins (comma-separated, optional override)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# CSRF Configuration (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173

# Environment
ENVIRONMENT=development
